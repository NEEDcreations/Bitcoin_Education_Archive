# Bitcoin Education Archive - Git Attributes
# [AUDIT FIX B5] Normalize line endings

# Auto-detect text files and normalize line endings
* text=auto

# Force specific file types
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rules text eol=lf
*.sh text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
